<style type='text/css'>
*{margin:0;padding:0;box-sizing:border-box}
html,body{min-height:100vh}
body{
  font-family:&#39;Rajdhani&#39;,sans-serif;
  color:#e2e8f0;
  background:#020617;
  background-image:
    radial-gradient(ellipse at top,rgba(0,255,136,0.15),transparent 50%),
    radial-gradient(ellipse at bottom,rgba(0,200,120,0.10),transparent 50%),
    linear-gradient(180deg,#020617 0%,#031a14 50%,#020617 100%);
  background-attachment:fixed;
  min-height:100vh;
  overflow-x:hidden;
}
body::before{
  content:&#39;&#39;;position:fixed;inset:0;pointer-events:none;z-index:0;
  background-image:
    radial-gradient(circle at 20% 30%,rgba(0,255,136,0.08) 0,transparent 2px),
    radial-gradient(circle at 80% 60%,rgba(0,255,136,0.08) 0,transparent 2px),
    radial-gradient(circle at 50% 80%,rgba(0,255,136,0.08) 0,transparent 2px);
  background-size:120px 120px,180px 180px,200px 200px;
}
a{color:inherit;text-decoration:none}
img{max-width:100%;height:auto;display:block}

/* Header */
.site-header{
  position:sticky;top:0;z-index:50;
  background:rgba(2,6,23,0.85);
  backdrop-filter:blur(12px);
  border-bottom:1px solid rgba(0,255,136,0.2);
}
.header-inner{
  display:flex;align-items:center;gap:12px;
  padding:14px 16px;max-width:1200px;margin:0 auto;
}
.logo{display:flex;align-items:center;gap:10px;font-family:&#39;Orbitron&#39;,sans-serif;font-weight:700;font-size:18px;color:#fff;flex-shrink:0}
.logo-icon{width:42px;height:42px;border:2px solid #00ff88;border-radius:10px;display:flex;align-items:center;justify-content:center;color:#00ff88;box-shadow:0 0 18px rgba(0,255,136,0.5),inset 0 0 12px rgba(0,255,136,0.15);background:rgba(0,255,136,0.05);flex-shrink:0}
.logo-icon svg{width:34px;height:34px;display:block}
.logo .accent{color:#00ff88}
.search-form{flex:1;display:flex;align-items:center;background:rgba(15,23,42,0.8);border:1px solid rgba(0,255,136,0.3);border-radius:8px;padding:6px 10px;max-width:500px}
.search-form input{flex:1;background:transparent;border:0;outline:0;color:#e2e8f0;font-family:inherit;font-size:14px;padding:4px 6px}
.search-form input::placeholder{color:#64748b}
.search-form button{background:transparent;border:0;color:#00ff88;cursor:pointer;padding:4px}
.menu-toggle{background:transparent;border:0;color:#00ff88;cursor:pointer;padding:6px;flex-shrink:0}
.menu-toggle svg{width:28px;height:28px}

/* Side Menu */
.side-menu{
  position:fixed;top:0;right:-340px;width:320px;max-width:85vw;height:100vh;
  background:linear-gradient(180deg,#031a14,#020617);
  border-left:1px solid rgba(0,255,136,0.3);
  z-index:200;transition:right .3s ease;overflow-y:auto;
  box-shadow:-10px 0 30px rgba(0,0,0,0.5);
}
.side-menu.open{right:0}
.side-menu-header{display:flex;justify-content:space-between;align-items:center;padding:18px;border-bottom:1px solid rgba(0,255,136,0.2)}
.side-menu-header h3{font-family:&#39;Orbitron&#39;,sans-serif;color:#00ff88;font-size:16px;letter-spacing:2px}
.menu-close{background:transparent;border:1px solid rgba(0,255,136,0.4);color:#00ff88;width:34px;height:34px;border-radius:6px;cursor:pointer;font-size:18px;display:flex;align-items:center;justify-content:center}
.side-menu nav{padding:14px}
.side-menu nav a{
  display:block;padding:14px 16px;margin-bottom:8px;
  color:#e2e8f0;font-weight:600;font-size:15px;
  border:1px solid rgba(0,255,136,0.15);border-radius:8px;
  background:rgba(0,255,136,0.04);transition:all .2s;
}
.side-menu nav a:hover{background:rgba(0,255,136,0.12);border-color:#00ff88;color:#00ff88;transform:translateX(-4px)}
.menu-section-title{color:#00ff88;font-family:&#39;Orbitron&#39;,sans-serif;font-size:12px;letter-spacing:2px;padding:14px 16px 6px;opacity:.7}
.menu-overlay{position:fixed;inset:0;background:rgba(0,0,0,0.6);z-index:150;opacity:0;pointer-events:none;transition:opacity .3s}
.menu-overlay.open{opacity:1;pointer-events:auto}

/* Main */
main{position:relative;z-index:1;max-width:1200px;margin:0 auto;padding:24px 16px}

/* Landing/Hero */
.hero{text-align:center;padding:40px 16px 30px}
.hero-tag{display:inline-block;border:1px solid #00ff88;color:#00ff88;font-family:&#39;Orbitron&#39;,sans-serif;font-size:12px;letter-spacing:3px;padding:8px 20px;border-radius:4px;margin-bottom:24px}
.hero h1{font-family:&#39;Orbitron&#39;,sans-serif;font-weight:900;font-size:clamp(40px,9vw,84px);line-height:1.05;color:#fff;margin-bottom:16px;text-shadow:0 0 30px rgba(0,255,136,0.3)}
.hero h1 .accent{color:#00ff88;text-shadow:0 0 25px rgba(0,255,136,0.6)}
.hero-sub{font-size:clamp(18px,4vw,24px);color:#fff;margin-bottom:18px;font-weight:500}
.hero-divider{width:60%;max-width:300px;height:1px;background:linear-gradient(90deg,transparent,#00ff88,transparent);margin:0 auto 22px}
.hero-desc{max-width:560px;margin:0 auto 28px;color:#cbd5e1;line-height:1.6;font-size:16px}
.home-btn{display:inline-flex;align-items:center;gap:10px;padding:16px 50px;border:2px solid #00ff88;color:#00ff88;font-family:&#39;Orbitron&#39;,sans-serif;font-weight:700;letter-spacing:3px;border-radius:10px;background:rgba(0,255,136,0.05);box-shadow:0 0 25px rgba(0,255,136,0.4),inset 0 0 20px rgba(0,255,136,0.1);transition:all .25s}
.home-btn:hover{background:rgba(0,255,136,0.15);box-shadow:0 0 40px rgba(0,255,136,0.7)}

/* Section heading */
.section-title{font-family:&#39;Orbitron&#39;,sans-serif;color:#00ff88;font-size:22px;letter-spacing:2px;margin:30px 0 18px;padding-bottom:10px;border-bottom:1px solid rgba(0,255,136,0.2)}

/* Posts grid */
.posts-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:20px}
.post-card{
  background:linear-gradient(145deg,rgba(15,23,42,0.8),rgba(2,6,23,0.9));
  border:1px solid rgba(0,255,136,0.2);
  border-radius:14px;overflow:hidden;
  transition:all .3s;
  box-shadow:0 4px 20px rgba(0,0,0,0.4);
  display:flex;flex-direction:column;
}
.post-card:hover{transform:translateY(-6px);border-color:#00ff88;box-shadow:0 10px 35px rgba(0,255,136,0.25)}
.post-thumb{aspect-ratio:16/9;overflow:hidden;background:#0f172a;border-bottom:1px solid rgba(0,255,136,0.15)}
.post-thumb img{width:100%;height:100%;object-fit:cover;transition:transform .4s}
.post-card:hover .post-thumb img{transform:scale(1.05)}
.post-body{padding:18px;flex:1;display:flex;flex-direction:column}
.post-title{font-family:&#39;Orbitron&#39;,sans-serif;font-size:17px;font-weight:700;color:#fff;margin-bottom:10px;line-height:1.3}
.post-title a:hover{color:#00ff88}
.post-meta{font-size:12px;color:#64748b;margin-bottom:10px;display:flex;gap:10px;flex-wrap:wrap}
.post-meta .label{color:#00ff88}
.post-snippet{color:#cbd5e1;font-size:14px;line-height:1.55;margin-bottom:14px;flex:1}
.read-more{align-self:flex-start;display:inline-block;padding:8px 18px;border:1px solid #00ff88;color:#00ff88;border-radius:6px;font-weight:600;font-size:13px;letter-spacing:1px;transition:all .2s}
.read-more:hover{background:#00ff88;color:#020617;box-shadow:0 0 18px rgba(0,255,136,0.5)}

/* Single post */
.post-full{background:rgba(15,23,42,0.6);border:1px solid rgba(0,255,136,0.2);border-radius:14px;padding:24px;margin-bottom:20px}
.post-full h1{font-family:&#39;Orbitron&#39;,sans-serif;color:#fff;font-size:28px;margin-bottom:14px;line-height:1.25}
.post-full .post-content{color:#e2e8f0;line-height:1.75;font-size:16px}
.post-full .post-content img{border-radius:8px;margin:14px 0}
.post-full .post-content h2,.post-full .post-content h3{color:#00ff88;font-family:&#39;Orbitron&#39;,sans-serif;margin:18px 0 10px}
.post-full .post-content a{color:#00ff88;text-decoration:underline}
.post-full .post-content p{margin-bottom:14px}

/* Pagination */
.blog-pager{text-align:center;padding:24px 0;display:flex;justify-content:center;gap:12px;flex-wrap:wrap}
.blog-pager a{display:inline-block;padding:10px 22px;border:1px solid #00ff88;color:#00ff88;border-radius:8px;font-weight:600;transition:all .2s}
.blog-pager a:hover{background:#00ff88;color:#020617}

/* Footer */
.site-footer{margin-top:50px;padding:30px 16px;border-top:1px solid rgba(0,255,136,0.2);background:rgba(2,6,23,0.6);position:relative;z-index:1}
.footer-inner{max-width:1200px;margin:0 auto;text-align:center}
.footer-links{display:flex;flex-wrap:wrap;justify-content:center;gap:8px 18px;margin-bottom:18px}
.footer-links a{color:#cbd5e1;font-size:14px;padding:6px 10px;border-radius:6px;transition:all .2s}
.footer-links a:hover{color:#00ff88;background:rgba(0,255,136,0.08)}
.footer-copy{color:#64748b;font-size:13px;font-family:&#39;Orbitron&#39;,sans-serif;letter-spacing:1px}
.footer-copy .accent{color:#00ff88}

/* Hide unused widget chrome */
.widget h2.title{display:none}
.widget-item-control,.quickedit{display:none !important}

@media(max-width:768px){
  .posts-grid{grid-template-columns:1fr;gap:16px}
  main{padding:16px 12px}
  .section-title{font-size:18px;margin:24px 0 14px}
}
@media(max-width:600px){
  .header-inner{padding:10px 12px;gap:8px;flex-wrap:wrap}
  .logo{font-size:14px;order:1}
  .logo-icon{width:36px;height:36px}
  .logo-icon svg{width:28px;height:28px}
  .menu-toggle{order:2;margin-left:auto}
  .search-form{order:3;flex-basis:100%;max-width:none;padding:6px 10px}
  .hero{padding:24px 8px 20px}
  .hero h1{font-size:44px}
  .hero-sub{font-size:17px}
  .hero-desc{font-size:15px;padding:0 4px}
  .home-btn{padding:14px 36px;letter-spacing:2px;font-size:14px}
  .post-full{padding:16px}
  .post-full h1{font-size:20px}
  .post-card{border-radius:12px}
  .post-title{font-size:16px}
  .side-menu{width:280px}
  .footer-links{gap:6px 10px}
  .footer-links a{font-size:13px;padding:5px 8px}
}
@media(max-width:380px){
  .hero h1{font-size:36px}
  .logo span:not(.accent){font-size:13px}
}
</style>

</head>

